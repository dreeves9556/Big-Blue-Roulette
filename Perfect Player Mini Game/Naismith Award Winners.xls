<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel" xmlns="http://www.w3.org/TR/REC-html40"><head><!--[if gte mso 9]><xml><x:ExcelWorkbook><x:ExcelWorksheets><x:ExcelWorksheet><x:Name>Worksheet</x:Name><x:WorksheetOptions><x:DisplayGridlines/></x:WorksheetOptions></x:ExcelWorksheet></x:ExcelWorksheets></x:ExcelWorkbook></xml><![endif]--></head><body><table>
    
    

   
   <thead>

      
      <tr class="over_header">
         <th aria-label="" data-stat="" colspan="3" class=" over_header center"></th>
         <th aria-label="" data-stat="header_totals" colspan="8" class=" over_header center">Totals</th>
         <th aria-label="" data-stat="header_shooting" colspan="4" class=" over_header center">Shooting</th>
         <th aria-label="" data-stat="header_per_g" colspan="5" class=" over_header center">Per Game</th>
      </tr>
            
      <tr>
         <th aria-label="Season" data-stat="season" scope="col" class=" poptip sort_default_asc left">Season</th>
         <th aria-label="Player" data-stat="player" scope="col" class=" poptip sort_default_asc left">Player</th>
         <th aria-label="School" data-stat="school_name" scope="col" class=" poptip sort_default_asc left" data-tip="* = NCAA Tournament appearance">School</th>
         <th aria-label="Games" data-stat="games" scope="col" class=" poptip right" data-tip="Games" data-over-header="Totals">G</th>
         <th aria-label="GS" data-stat="games_started" scope="col" class=" poptip right" data-tip="Games Started" data-over-header="Totals">GS</th>
         <th aria-label="Points" data-stat="pts" scope="col" class=" poptip right" data-tip="Points" data-over-header="Totals">PTS</th>
         <th aria-label="Total Rebounds" data-stat="trb" scope="col" class=" poptip right" data-tip="Total Rebounds" data-over-header="Totals">TRB</th>
         <th aria-label="Assists" data-stat="ast" scope="col" class=" poptip right" data-tip="Assists" data-over-header="Totals">AST</th>
         <th aria-label="Steals" data-stat="stl" scope="col" class=" poptip right" data-tip="Steals" data-over-header="Totals">STL</th>
         <th aria-label="Blocks" data-stat="blk" scope="col" class=" poptip right" data-tip="Blocks" data-over-header="Totals">BLK</th>
         <th aria-label="Win Shares" data-stat="ws" scope="col" class=" poptip right" data-tip="Win Shares; an estimate of the number of wins contributed by a player due to their offense and defense." data-over-header="Totals" data-filter="1" data-name="Win Shares">WS</th>
         <th aria-label="Field Goal Percentage" data-stat="fg_pct" scope="col" class=" poptip right" data-tip="Field Goal Percentage" data-over-header="Shooting" data-filter="1" data-name="Field Goal Percentage">FG%</th>
         <th aria-label="2-Point Field Goal Percentage" data-stat="fg2_pct" scope="col" class=" poptip right" data-tip="2-Point Field Goal Percentage" data-over-header="Shooting" data-filter="1" data-name="2-Point Field Goal Percentage">2P%</th>
         <th aria-label="3-Point Field Goal Percentage" data-stat="fg3_pct" scope="col" class=" poptip right" data-tip="3-Point Field Goal Percentage" data-over-header="Shooting" data-filter="1" data-name="3-Point Field Goal Percentage">3P%</th>
         <th aria-label="Free Throw Percentage" data-stat="ft_pct" scope="col" class=" poptip right" data-tip="Free Throw Percentage" data-over-header="Shooting" data-filter="1" data-name="Free Throw Percentage">FT%</th>
         <th aria-label="Points Per Game" data-stat="pts_per_g" scope="col" class=" poptip right" data-tip="Points Per Game" data-over-header="Per Game" data-filter="1" data-name="Points Per Game">PTS</th>
         <th aria-label="Total Rebounds Per Game" data-stat="trb_per_g" scope="col" class=" poptip right" data-tip="Total Rebounds Per Game" data-over-header="Per Game" data-filter="1" data-name="Total Rebounds Per Game">TRB</th>
         <th aria-label="Assists Per Game" data-stat="ast_per_g" scope="col" class=" poptip right" data-tip="Assists Per Game" data-over-header="Per Game" data-filter="1" data-name="Assists Per Game">AST</th>
         <th aria-label="Steals Per Game" data-stat="stl_per_g" scope="col" class=" poptip right" data-tip="Steals Per Game" data-over-header="Per Game" data-filter="1" data-name="Steals Per Game">STL</th>
         <th aria-label="Blocks Per Game" data-stat="blk_per_g" scope="col" class=" poptip right" data-tip="Blocks Per Game" data-over-header="Per Game" data-filter="1" data-name="Blocks Per Game">BLK</th>
      </tr>
      </thead>
